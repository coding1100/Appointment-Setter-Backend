# ===========================================
# AI Phone Scheduler SaaS Platform
# Environment Configuration Template
# ===========================================

# Firebase Configuration (Minimal Required Fields)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@your-project.iam.gserviceaccount.com

# Redis Configuration (for session management and slot holds)
REDIS_URL=redis://localhost:6379/0

# LiveKit Cloud Configuration (for voice agents)
LIVEKIT_API_KEY=APIDGB4b29MGuN2
LIVEKIT_API_SECRET=7tftDFeSpRPPa9uDERIyPxjS1AFLvrzF9hvhxrM5dly
LIVEKIT_URL=wss://appointment-setter-u2gpzvxc.livekit.cloud

# LiveKit SIP Configuration (for inbound calls from Twilio)
# SIP domain from LiveKit Cloud dashboard → SIP → Inbound Trunks
# Example: 3nbu801ppzl.sip.livekit.cloud
LIVEKIT_SIP_DOMAIN=3nbu801ppzl.sip.livekit.cloud

# Twilio Configuration (for phone integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# AI Services Configuration
GOOGLE_API_KEY=your_google_api_key_here
DEEPGRAM_API_KEY=8b2de4b755f7a7557100eccb446f0341cf497fba
ELEVEN_API_KEY=sk_4921468e8411f6b970ddc80ddda164d64a0e0ff2f214e04f
AGENT_VOICE=Assistant

# Gemini TTS (primary) + ElevenLabs (fallback)
VOICE_TTS_PRIMARY_PROVIDER=gemini
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE_MALE=Orus
GEMINI_TTS_VOICE_FEMALE=Aoede
ELEVEN_TTS_MODEL=eleven_turbo_v2_5

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=production
# Comma-separated list. Use * only in local/dev.
CORS_ALLOW_ORIGINS=*

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# Security Configuration
SECRET_KEY=your_secret_key_for_jwt_tokens_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# Chatbot Embed Configuration
# CHATBOT_EMBED_SECRET defaults to SECRET_KEY when omitted
CHATBOT_EMBED_SECRET=your_optional_chatbot_embed_secret_here
CHATBOT_EMBED_TOKEN_TTL_MINUTES=60
CHATBOT_LOADER_BASE_URL=https://your-api-domain.com/api/v1/chatbot-embed/loader.js
CHATBOT_TEXT_MODEL=gemini-2.0-flash
CHATBOT_LLM_PROVIDER=gemini
CHATBOT_STREAM_TIMEOUT_SECONDS=60
CHATBOT_DEV_ALLOW_ANY_ORIGIN=false
CHATBOT_RUNTIME_ENABLED=true

GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id

# ===========================================
# FIREBASE SETUP INSTRUCTIONS:
# ===========================================
# 1. Go to https://console.firebase.google.com
# 2. Create a new project
# 3. Go to Project Settings > Service Accounts
# 4. Generate a new private key (downloads JSON file)
# 5. Extract ONLY these 3 values from the JSON file:
#    - project_id -> FIREBASE_PROJECT_ID
#    - private_key -> FIREBASE_PRIVATE_KEY
#    - client_email -> FIREBASE_CLIENT_EMAIL
# 6. Enable Firestore Database in Firebase Console
# 7. Enable Authentication in Firebase Console
# ===========================================
