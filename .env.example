# ===========================================
# AI Phone Scheduler SaaS Platform
# Environment Configuration Template
# ===========================================

# PostgreSQL Configuration (primary persistence)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/appointment_setter
DATABASE_POOL_SIZE=10
DATABASE_POOL_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# LiveKit Cloud Configuration (for voice agents)
LIVEKIT_API_KEY=APIDGB4b29MGuN2
LIVEKIT_API_SECRET=7tftDFeSpRPPa9uDERIyPxjS1AFLvrzF9hvhxrM5dly
LIVEKIT_URL=wss://appointment-setter-u2gpzvxc.livekit.cloud

# LiveKit SIP Configuration (for inbound calls from Twilio)
# SIP domain from LiveKit Cloud dashboard → SIP → Inbound Trunks
# Example: 3nbu801ppzl.sip.livekit.cloud
LIVEKIT_SIP_DOMAIN=3nbu801ppzl.sip.livekit.cloud

# Twilio Configuration (for phone integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# AI Services Configuration
# Gemini Live handles VAD, STT, LLM reasoning and TTS in one model,
# so only the Google API key is needed for the voice pipeline.
GOOGLE_API_KEY=your_google_api_key_here

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=production
# Comma-separated list. Use * in development (maps to localhost origins automatically).
# For Docker/production, list explicit frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Security Configuration
SECRET_KEY=your_secret_key_for_jwt_tokens_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# Chatbot Embed Configuration
# CHATBOT_EMBED_SECRET defaults to SECRET_KEY when omitted
CHATBOT_EMBED_SECRET=your_optional_chatbot_embed_secret_here
CHATBOT_EMBED_TOKEN_TTL_MINUTES=60
CHATBOT_LOADER_BASE_URL=https://your-api-domain.com/api/v1/chatbot-embed/loader.js
CHATBOT_TEXT_MODEL=gemini-2.5-flash-lite
CHATBOT_LLM_PROVIDER=gemini
CHATBOT_STREAM_TIMEOUT_SECONDS=60
CHATBOT_DEV_ALLOW_ANY_ORIGIN=false
CHATBOT_RUNTIME_ENABLED=true

GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
